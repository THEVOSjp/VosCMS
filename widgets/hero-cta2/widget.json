            },
            {
                "key": "typing_speed",
                "type": "select",
                "label": "Typing Speed",
                "options": [
                    {
                        "value": "fast",
                        "label": "Fast (100ms)"
                    },
                    {
                        "value": "normal",
                        "label": "Normal (160ms)"
                    },
                    {
                        "value": "slow",
                        "label": "Slow (220ms)"
                    }
                ],
                "default": "normal"
            },
            {
                "key": "tagline_bottom",
