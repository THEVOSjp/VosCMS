{
    "slug": "services",
    "version": "2.0.0",
    "author": "VosCMS",
    "category": "content",
    "icon": "briefcase",
    "thumbnail": "thumbnail.png",
    "name": {
        "ko": "인기 서비스", "en": "Popular Services", "ja": "人気サービス",
        "zh_CN": "热门服务", "zh_TW": "熱門服務", "de": "Beliebte Dienste",
        "es": "Servicios Populares", "fr": "Services Populaires",
        "id": "Layanan Populer", "mn": "Алдартай үйлчилгээ", "ru": "Популярные услуги",
        "tr": "Popüler Hizmetler", "vi": "Dịch vụ Phổ biến"
    },
    "description": {
        "ko": "가장 많이 찾는 서비스를 카드 형태로 표시합니다",
        "en": "Display popular services in card layout",
        "ja": "人気サービスをカード形式で表示します",
        "zh_CN": "以卡片形式展示热门服务", "zh_TW": "以卡片形式展示熱門服務",
        "de": "Beliebte Dienste als Karten anzeigen",
        "es": "Mostrar servicios populares en tarjetas",
        "fr": "Afficher les services populaires sous forme de cartes",
        "id": "Tampilkan layanan populer dalam bentuk kartu",
        "mn": "Алдартай үйлчилгээг карт хэлбэрээр харуулах",
        "ru": "Отображение популярных услуг в виде карточек",
        "tr": "Popüler hizmetleri kart düzeninde göster",
        "vi": "Hiển thị dịch vụ phổ biến dưới dạng thẻ"
    },
    "config_schema": {
        "fields": [
            {"key": "title", "type": "text", "label": "Section Title", "i18n": true, "default": "Popular Services"},
            {"key": "subtitle", "type": "textarea", "label": "Section Subtitle", "i18n": true},
            {"key": "style", "type": "select", "label": "Card Style", "options": [
                {"value": "card", "label": "Card (Default)"},
                {"value": "minimal", "label": "Minimal List"},
                {"value": "overlay", "label": "Image Overlay"}
            ], "default": "card"},
            {"key": "columns", "type": "select", "label": "Columns", "options": [
                {"value": "2", "label": "2 Columns"},
                {"value": "3", "label": "3 Columns"},
                {"value": "4", "label": "4 Columns"}
            ], "default": "3"},
            {"key": "count", "type": "number", "label": "Max Items", "default": 6},
            {"key": "currency", "type": "text", "label": "Currency Symbol", "default": "¥"},
            {"key": "show_price", "type": "toggle", "label": "Show Price", "default": true},
            {"key": "show_duration", "type": "toggle", "label": "Show Duration", "default": true},
            {"key": "bg_color", "type": "color_transparent", "label": "Background Color", "default": "transparent"},
            {"key": "service_items", "type": "service_items", "label": "Service Items"}
        ]
    }
}
