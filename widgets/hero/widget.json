{
    "slug": "hero",
    "version": "1.0.0",
    "author": "RezlyX",
    "category": "layout",
    "icon": "sparkles",
    "thumbnail": "thumbnail.png",
    "name": {
        "ko": "히어로 배너",
        "en": "Hero Banner",
        "ja": "ヒーローバナー",
        "zh_CN": "主横幅",
        "zh_TW": "主橫幅",
        "de": "Hero-Banner",
        "es": "Banner Principal",
        "fr": "Bannière Principale",
        "id": "Banner Utama",
        "mn": "Гол баннер",
        "ru": "Главный баннер",
        "tr": "Ana Banner",
        "vi": "Banner Chính"
    },
    "description": {
        "ko": "메인 배너 (제목, 부제, CTA 버튼)",
        "en": "Main hero section with title, subtitle, CTA button",
        "ja": "メインバナー（タイトル、サブタイトル、CTAボタン）",
        "zh_CN": "主横幅区域（标题、副标题、CTA按钮）",
        "zh_TW": "主橫幅區域（標題、副標題、CTA按鈕）",
        "de": "Hauptbanner mit Titel, Untertitel und CTA-Button",
        "es": "Banner principal con título, subtítulo y botón CTA",
        "fr": "Bannière principale avec titre, sous-titre et bouton CTA",
        "id": "Banner utama dengan judul, subjudul, dan tombol CTA",
        "mn": "Гол баннер (гарчиг, дэд гарчиг, CTA товч)",
        "ru": "Главный баннер с заголовком, подзаголовком и кнопкой CTA",
        "tr": "Ana banner: başlık, alt başlık ve CTA düğmesi",
        "vi": "Banner chính với tiêu đề, phụ đề và nút CTA"
    },
    "config_schema": {
        "fields": [
            {"key": "title", "type": "text", "label": "Title", "i18n": true, "default": "Welcome"},
            {"key": "subtitle", "type": "textarea", "label": "Subtitle", "i18n": true},
            {"key": "layout", "type": "select", "label": "Layout", "options": [
                {"value": "center", "label": "Center Aligned"},
                {"value": "fullscreen", "label": "Full Screen"},
                {"value": "left-image", "label": "Left Image + Right Text"},
                {"value": "right-image", "label": "Right Image + Left Text"}
            ], "default": "center"},
            {"key": "height", "type": "select", "label": "Height", "options": [
                {"value": "small", "label": "Small"},
                {"value": "medium", "label": "Medium"},
                {"value": "large", "label": "Large"},
                {"value": "full", "label": "Full Screen"}
            ], "default": "medium"},
            {"key": "bg_type", "type": "select", "label": "Background Type", "options": [
                {"value": "gradient", "label": "Gradient"},
                {"value": "solid", "label": "Solid Color"},
                {"value": "image", "label": "Image"},
                {"value": "video", "label": "Video"}
            ], "default": "gradient"},
            {"key": "bg_color", "type": "color", "label": "Background Color", "default": "#2563eb"},
            {"key": "bg_gradient_from", "type": "color", "label": "Gradient From", "default": "#2563eb"},
            {"key": "bg_gradient_to", "type": "color", "label": "Gradient To", "default": "#1e40af"},
            {"key": "bg_image", "type": "image", "label": "Background Image"},
            {"key": "bg_video", "type": "video", "label": "Background Video"},
            {"key": "bg_overlay", "type": "range", "label": "Overlay Opacity", "min": 0, "max": 100, "default": 50},
            {"key": "hero_images", "type": "hero_images", "label": "Hero Images"},
            {"key": "buttons", "type": "buttons", "label": "Buttons"},
            {"key": "element_positions", "type": "hidden"}
        ]
    }
}
