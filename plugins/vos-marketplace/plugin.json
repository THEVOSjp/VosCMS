  "version": "1.0.0",
  "author": {
    "name": "VosCMS",
    "url": "https://voscms.com"
  },
  "license": "proprietary",
  "category": "system",
  "tags": ["marketplace", "plugins", "themes", "widgets", "skins"],

  "requires": {
    "php": ">=8.0"
  },

  "migrations": [
    "migrations/001_create_marketplace_tables.sql",
    "migrations/002_create_license_tables.sql",
    "migrations/003_create_review_tables.sql"
  ],

  "routes": {
    "admin": [
      { "path": "marketplace", "view": "admin/browse.php", "method": "GET" },
      { "path": "marketplace/item", "view": "admin/item-detail.php", "method": "GET" },
      { "path": "marketplace/purchases", "view": "admin/purchases.php", "method": "GET" },
      { "path": "marketplace/licenses", "view": "admin/licenses.php", "method": "GET" },
      { "path": "marketplace/settings", "view": "admin/settings.php", "method": "GET" },
      { "path": "marketplace/api", "view": "admin/api.php", "method": "POST" },
      { "path": "marketplace/install", "view": "admin/install-handler.php", "method": "POST" }
    ],
    "front": [],
    "api": [
      { "path": "api/marketplace/catalog", "view": "api/catalog.php", "method": "GET" },
      { "path": "api/marketplace/item", "view": "api/item.php", "method": "GET" },
      { "path": "api/marketplace/purchase", "view": "api/purchase.php", "method": "POST" },
      { "path": "api/marketplace/license/validate", "view": "api/license-validate.php", "method": "POST" },
      { "path": "api/marketplace/download", "view": "api/download.php", "method": "GET" },
      { "path": "api/marketplace/webhook", "view": "api/webhook.php", "method": "POST" }
    ]
  },

