        "items": [
          { "title": { "ko": "탐색", "en": "Browse", "ja": "検索", "de": "Durchsuchen", "es": "Explorar", "fr": "Parcourir", "id": "Jelajahi", "mn": "Хайх", "ru": "Обзор", "tr": "Gözat", "vi": "Duyệt", "zh_CN": "浏览", "zh_TW": "瀏覽" }, "route": "marketplace" },
