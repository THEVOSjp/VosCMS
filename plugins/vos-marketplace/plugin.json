  "hooks": {
    "admin.dashboard.render": "hooks/dashboard-widget.php",
    "plugin.update.check": "hooks/update-check.php"
  },

  "settings": {
    "defaults": {
      "marketplace_api_url": "https://marketplace.voscms.com/api",
      "auto_update_check": "1",
      "update_check_interval": "86400"
    }
