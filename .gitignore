.env
/node_modules/
/storage/uploads/*
/storage/board/*
/storage/backups/*
/storage/logs/*
/storage/framework/sessions/*
/storage/framework/cache/*
/storage/framework/views/*
/storage/.installed

# 런타임 캐시·업로드 자산 (관리자 화면에서 생성/업로드)
/storage/cache/mp_api_*.json
/storage/cache/sitemap.xml
/storage/cache/voscms_notices_*.json
/storage/favicon_*
/storage/mobile_icon_*
/storage/og_image_*
/storage/logos/
/storage/skins/
/storage/pwa/

!/storage/.gitkeep
!/storage/uploads/.gitkeep
!/storage/board/.gitkeep
!/storage/logs/.gitkeep
*.log
.DS_Store
Thumbs.db
storage/sessions/

# DB 덤프 (수동 백업) — 절대 깃에 올리지 말 것
/database/*.sql
/database/*.sql.gz
!/database/migrate_*.sql


# Local IDE/agent settings
.claude/
