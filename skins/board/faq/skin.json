{
  "title": { "ko": "FAQ 아코디언 스킨", "en": "FAQ Accordion Skin", "ja": "FAQアコーディオンスキン", "de": "FAQ Akkordeon Skin", "es": "Skin FAQ Acordeón", "fr": "Skin FAQ Accordéon", "id": "Skin FAQ Akordeon", "mn": "FAQ Аккордеон скин", "ru": "FAQ Аккордеон скин", "tr": "FAQ Akordeon Skin", "vi": "Skin FAQ Accordion", "zh_CN": "FAQ手风琴皮肤", "zh_TW": "FAQ手風琴面板" },
