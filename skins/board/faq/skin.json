      "title": { "ko": "프라이머리 색상", "en": "Primary Color", "ja": "プライマリカラー" },
      "default": "#22c55e"
    },
    {
      "name": "posts_per_page",
      "type": "number",
      "title": { "ko": "페이지당 표시 수", "en": "Items per page", "ja": "1ページの表示数" },
      "description": { "ko": "한 페이지에 표시할 FAQ 수 (기본: 10)", "en": "Number of FAQ items per page (default: 10)", "ja": "1ページに表示するFAQ数（デフォルト：10）" },
